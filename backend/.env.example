# ── Server ───────────────────────────────
PORT=8000
HOST=0.0.0.0

# ── Model Paths (relative to backend/) ───
MODEL_DIR=./models
MODEL_FILE=emotion_keras_model_22113034.h5
SCALER_FILE=minmax_scaler_22113034.pkl
PCA_FILE=pca_transform_22113034.pkl

# ── Audio Constraints ────────────────────
MAX_AUDIO_SIZE_MB=10
MAX_AUDIO_DURATION_SEC=30
AUDIO_SAMPLE_RATE=22050
AUDIO_FEATURE_DURATION=3

# ── Database ─────────────────────────────
DATABASE_URL=sqlite:///./voxemo.db

# ── Groq API (for future LLM features) ───
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-8b-8192
